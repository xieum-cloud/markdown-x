{
  "name": "markdown-x",
  "displayName": "Markdown X",
  "description": "Ultimate Markdown Viewer with PDF/Word export, page-aware layout, Mermaid diagrams, KaTeX math, and custom themes",
  "version": "0.1.2",
  "publisher": "xieum-cloud",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/xieum-cloud/markdown-x"
  },
  "homepage": "https://github.com/xieum-cloud/markdown-x#readme",
  "bugs": {
    "url": "https://github.com/xieum-cloud/markdown-x/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "galleryBanner": {
    "color": "#1e3a5f",
    "theme": "dark"
  },
  "localizedResources": {
    "package": [
      "./package.nls.json",
      "./package.nls.ko.json"
    ]
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "markdown",
    "viewer",
    "preview",
    "toc",
    "mermaid",
    "theme",
    "lightbox"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:markdown-x.openPreview",
    "onCommand:markdown-x.exportPdf",
    "onCommand:markdown-x.exportDocx",
    "onCommand:markdown-x.print",
    "onView:markdown-x-toc"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "markdown-x.openPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == markdown"
      },
      {
        "command": "markdown-x.togglePagePreview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == markdown"
      }
    ],
    "commands": [
      {
        "command": "markdown-x.openPreview",
        "title": "%markdown-x.commands.openPreview%",
        "category": "Markdown X",
        "icon": "$(open-preview)"
      },
      {
        "command": "markdown-x.refreshPreview",
        "title": "%markdown-x.commands.refreshPreview%",
        "category": "Markdown X",
        "icon": "$(refresh)"
      },
      {
        "command": "markdown-x.exportPdf",
        "title": "%markdown-x.commands.exportPdf%",
        "category": "Markdown X",
        "icon": {
          "dark": "images/icons/export-pdf-dark.svg",
          "light": "images/icons/export-pdf-light.svg"
        }
      },
      {
        "command": "markdown-x.exportDocx",
        "title": "%markdown-x.commands.exportDocx%",
        "category": "Markdown X",
        "icon": {
          "dark": "images/icons/export-docx-dark.svg",
          "light": "images/icons/export-docx-light.svg"
        }
      },
      {
        "command": "markdown-x.print",
        "title": "%markdown-x.commands.print%",
        "category": "Markdown X",
        "icon": "$(output)"
      },
      {
        "command": "markdown-x.increaseFontSize",
        "title": "%markdown-x.commands.increaseFontSize%",
        "category": "Markdown X",
        "icon": "$(add)"
      },
      {
        "command": "markdown-x.decreaseFontSize",
        "title": "%markdown-x.commands.decreaseFontSize%",
        "category": "Markdown X",
        "icon": "$(remove)"
      },
      {
        "command": "markdown-x.setFontSize",
        "title": "%markdown-x.commands.setFontSize%",
        "category": "Markdown X",
        "icon": "$(text-size)"
      },
      {
        "command": "markdown-x.changeFontFamily",
        "title": "%markdown-x.commands.changeFontFamily%",
        "category": "Markdown X",
        "icon": "$(whole-word)"
      },
      {
        "command": "markdown-x.changeTheme",
        "title": "%markdown-x.commands.changeTheme%",
        "category": "Markdown X",
        "icon": "$(color-mode)"
      },
      {
        "command": "markdown-x.togglePagePreview",
        "title": "%markdown-x.commands.togglePagePreview%",
        "category": "Markdown X",
        "icon": {
          "dark": "images/icons/page-preview-dark.svg",
          "light": "images/icons/page-preview-light.svg"
        }
      },
      {
        "command": "markdown-x.changePageSize",
        "title": "%markdown-x.commands.changePageSize%",
        "category": "Markdown X",
        "icon": "$(notebook)"
      },
      {
        "command": "markdown-x.changeMargin",
        "title": "%markdown-x.commands.changeMargin%",
        "category": "Markdown X",
        "icon": "$(layout)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdown-x.openPreview",
          "group": "navigation",
          "when": "editorLangId == markdown"
        },
        {
          "command": "markdown-x.togglePagePreview",
          "group": "navigation@1",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.exportPdf",
          "group": "navigation@2",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.exportDocx",
          "group": "navigation@3",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.changeFontFamily",
          "group": "1_mx@1",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.setFontSize",
          "group": "1_mx@2",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.changeTheme",
          "group": "1_mx@3",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.changePageSize",
          "group": "1_mx@4",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.changeMargin",
          "group": "1_mx@5",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.print",
          "group": "1_mx@6",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.refreshPreview",
          "group": "1_mx@7",
          "when": "markdown-x:previewOpen"
        }
      ],
      "editor/context": [
        {
          "command": "markdown-x.openPreview",
          "group": "markdown-x@1",
          "when": "editorLangId == markdown"
        }
      ],
      "commandPalette": [
        {
          "command": "markdown-x.openPreview",
          "when": "true"
        },
        {
          "command": "markdown-x.refreshPreview",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.exportPdf",
          "when": "true"
        },
        {
          "command": "markdown-x.exportDocx",
          "when": "true"
        },
        {
          "command": "markdown-x.print",
          "when": "true"
        },
        {
          "command": "markdown-x.setFontSize",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.changeFontFamily",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.changeTheme",
          "when": "markdown-x:previewOpen"
        },
        {
          "command": "markdown-x.togglePagePreview",
          "when": "true"
        },
        {
          "command": "markdown-x.changePageSize",
          "when": "true"
        },
        {
          "command": "markdown-x.changeMargin",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "%markdown-x.configuration.title%",
      "properties": {
        "markdown-x.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "light",
            "dark",
            "sepia"
          ],
          "enumDescriptions": [
            "%markdown-x.configuration.theme.enum.auto%",
            "%markdown-x.configuration.theme.enum.light%",
            "%markdown-x.configuration.theme.enum.dark%",
            "%markdown-x.configuration.theme.enum.sepia%"
          ],
          "description": "%markdown-x.configuration.theme%"
        },
        "markdown-x.fontSize": {
          "type": "number",
          "default": 16,
          "minimum": 10,
          "maximum": 32,
          "description": "%markdown-x.configuration.fontSize%"
        },
        "markdown-x.lineHeight": {
          "type": "number",
          "default": 1.6,
          "minimum": 1,
          "maximum": 3,
          "description": "%markdown-x.configuration.lineHeight%"
        },
        "markdown-x.enableMermaid": {
          "type": "boolean",
          "default": true,
          "description": "%markdown-x.configuration.enableMermaid%"
        },
        "markdown-x.enableImageLightbox": {
          "type": "boolean",
          "default": true,
          "description": "%markdown-x.configuration.enableImageLightbox%"
        },
        "markdown-x.enableScrollSync": {
          "type": "boolean",
          "default": true,
          "description": "%markdown-x.configuration.enableScrollSync%"
        },
        "markdown-x.maxTocLevel": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 6,
          "description": "%markdown-x.configuration.maxTocLevel%"
        },
        "markdown-x.fontFamily": {
          "type": "string",
          "default": "",
          "description": "%markdown-x.configuration.fontFamily%"
        },
        "markdown-x.codeFontFamily": {
          "type": "string",
          "default": "",
          "description": "%markdown-x.configuration.codeFontFamily%"
        },
        "markdown-x.customCssPath": {
          "type": "string",
          "default": "",
          "description": "%markdown-x.configuration.customCssPath%"
        },
        "markdown-x.customCss": {
          "type": "string",
          "default": "",
          "description": "%markdown-x.configuration.customCss%"
        },
        "markdown-x.pdf.pageSize": {
          "type": "string",
          "default": "A4",
          "enum": [
            "A4",
            "A3",
            "Letter",
            "Legal"
          ],
          "description": "%markdown-x.configuration.pdf.pageSize%"
        },
        "markdown-x.pdf.margin": {
          "type": "string",
          "default": "20mm",
          "description": "%markdown-x.configuration.pdf.margin%"
        },
        "markdown-x.pdf.headerFooter": {
          "type": "boolean",
          "default": true,
          "description": "%markdown-x.configuration.pdf.headerFooter%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "node esbuild.js",
    "bundle:watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "lint": "eslint src --ext ts",
    "test": "npx ts-node src/markdownParser.test.ts"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.0.0",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "highlight.js": "^11.0.0",
    "html-to-docx": "^1.8.0",
    "marked": "^12.0.0",
    "puppeteer-core": "^24.40.0"
  }
}
